APP_NAME="TZEL CAFÉ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:9000
# Production (DigitalOcean): https://tzelcafebackend-gixrp.ondigitalocean.app
APP_FORCE_HTTPS=false
ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tzelcafe
DB_USERNAME=tzelcafe
DB_PASSWORD=

# DigitalOcean managed MySQL (SSL required). Download CA from DO database settings if needed.
# MYSQL_ATTR_SSL_CA=/path/to/ca-certificate.crt
MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: list your frontend URLs comma-separated, OR use * to allow any origin:
# CORS_ALLOWED_ORIGINS=*
# CORS_ALLOW_ALL=true
FRONTEND_URL=http://localhost:5173

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:9000/auth/google/callback
ADMIN_NOTIFICATION_EMAIL=
  TZEL_PHONE="+254 142 958667"
TZEL_EMAIL=hello@tzelcafe.com
TZEL_WEBSITE=https://www.tzelcafe.com
TZEL_MPESA_TILL=3504735
TZEL_MPESA_PAYBILL=880100
TZEL_MPESA_ACCOUNT=PAYTZEL

DO_SPACES_SECRET=
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_URL=
FILESYSTEM_UPLOADS_DISK=public

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME="TZEL CAFÉ"

GROQ_API_KEY=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@tzelcafe.co.ke"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
